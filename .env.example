# .env — Copy to .env and fill in values
# For LOCAL development — skip AWS lookups

# ── Option A: Full URL (fastest for local dev) ────────────────────────
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/myflixdb

# ── Option B: Individual vars (also skips AWS) ────────────────────────
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=yourpassword
DB_NAME=myflixdb

# ── Option C: AWS (production — leave DB_HOST/USER/PASSWORD blank) ────
AWS_REGION=us-east-1
SECRET_NAME=awsb74-rds-creds
SSM_HOST_KEY=/b74/db_host
SSM_PORT_KEY=/b74/db_port
