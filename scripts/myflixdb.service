[Unit]
Description=MyFlixDB FastAPI Application
After=network.target

[Service]
User=ec2-user
Group=ec2-user
WorkingDirectory=/home/ec2-user/myflixdb
Environment="PATH=/home/ec2-user/myflixdb/venv/bin"
EnvironmentFile=/home/ec2-user/myflixdb/.env

# Gunicorn with Uvicorn workers — tune workers to (2 × vCPUs) + 1
ExecStart=/home/ec2-user/myflixdb/venv/bin/gunicorn \
    app.main:app \
    --workers 4 \
    --worker-class uvicorn.workers.UvicornWorker \
    --bind 127.0.0.1:8000 \
    --timeout 120 \
    --access-logfile /var/log/myflixdb/access.log \
    --error-logfile /var/log/myflixdb/error.log

Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
